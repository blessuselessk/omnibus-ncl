#!/usr/bin/env bash
set -euo pipefail

# ncl-run — execute a .ncl file by dispatching to the right runtime
#
# All six config types dispatch to real runtimes:
#   .script       → exec bash script (stdin passes through)
#   .processes    → exec process-compose up
#   .jobs.*       → run locally with act (requires Docker)
#   .target.kind  → envelope: extract innermost payload, run it
#   .worker       → porkg: run jobs sequentially
#   (version 1)   → seatbelt: sandbox-exec

# --- Tool resolution ---
if command -v nickel &>/dev/null; then
  ncl() { nickel "$@"; }
elif command -v nix &>/dev/null; then
  ncl() { nix run nixpkgs#nickel -- "$@"; }
else
  echo "error: nickel not found" >&2; exit 1
fi

if command -v jq &>/dev/null; then
  jq_() { jq "$@"; }
elif command -v nix &>/dev/null; then
  jq_() { nix run nixpkgs#jq -- "$@"; }
else
  echo "error: jq not found" >&2; exit 1
fi

run_act() {
  if command -v act &>/dev/null; then
    act "$@"
  elif command -v nix &>/dev/null; then
    nix run nixpkgs#act -- "$@"
  else
    echo "error: act not found. Install: nix shell nixpkgs#act" >&2; return 1
  fi
}

run_pc() {
  if command -v process-compose &>/dev/null; then
    process-compose "$@"
  elif command -v nix &>/dev/null; then
    nix run nixpkgs#process-compose -- "$@"
  else
    echo "error: process-compose not found" >&2; return 1
  fi
}

# --- Flags ---
DRY_RUN=false
JSON_ONLY=false
VERBOSE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    --json)    JSON_ONLY=true; shift ;;
    --verbose) VERBOSE=true; shift ;;
    --help|-h)
      echo "ncl-run — export a .ncl file and dispatch to the right runtime"
      echo ""
      echo "Usage: ncl-run [flags] <file.ncl> [-- args...]"
      echo ""
      echo "Flags:"
      echo "  --dry-run    Show what would run, don't execute"
      echo "  --json       Export JSON and stop"
      echo "  --verbose    Show extra detail"
      echo ""
      echo "Dispatches (all execute by default):"
      echo "  .script          → bash script (stdin pipes through)"
      echo "  .processes       → process-compose up --tui=false"
      echo "  .jobs.*.runs-on  → act (local GHA via Docker)"
      echo "  .target.kind     → envelope payload (sandbox-exec on macOS)"
      echo "  .worker          → porkg jobs (sequential)"
      echo "  (version 1)      → sandbox-exec -f <profile> <cmd>"
      exit 0 ;;
    -*) echo "Unknown flag: $1"; exit 1 ;;
    *)  break ;;
  esac
done

NCL_FILE="${1:?Usage: ncl-run <file.ncl>}"
shift || true
[[ -f "$NCL_FILE" ]] || { echo "error: $NCL_FILE not found" >&2; exit 1; }

# --- Step 1: Try seatbelt (text export) ---
TEXT=$(ncl export --format text "$NCL_FILE" 2>/dev/null || true)
if [[ "$TEXT" == "(version 1)"* ]]; then
  echo "==> Detected: seatbelt profile" >&2
  if $DRY_RUN; then
    echo "==> Would run: sandbox-exec -f <profile> <command>" >&2
    exit 0
  fi
  TMP=$(mktemp /tmp/ncl-run-XXXXXX.sb)
  echo "$TEXT" > "$TMP"
  if [[ $# -gt 0 ]]; then
    echo "==> Running: sandbox-exec -f $TMP $*" >&2
    exec sandbox-exec -f "$TMP" "$@"
  else
    echo "==> Profile: $TMP" >&2
    echo "==> Run: sandbox-exec -f $TMP <command>" >&2
  fi
  exit 0
fi

# --- Step 2: Export JSON ---
JSON=$(ncl export --format json "$NCL_FILE") || { echo "error: export failed" >&2; exit 1; }

if $JSON_ONLY; then
  echo "$JSON" | jq_ .
  exit 0
fi

# --- Step 3: Detect and dispatch ---

# 1. Shell script pipeline? (has .script field)
if echo "$JSON" | jq_ -e '.script // empty' &>/dev/null; then
  SCRIPT=$(echo "$JSON" | jq_ -r '.script')
  LINES=$(echo "$SCRIPT" | wc -l | tr -d ' ')
  echo "==> Detected: shell script ($LINES lines)" >&2
  if $DRY_RUN; then
    echo "$SCRIPT" >&2
    exit 0
  fi
  TMP=$(mktemp /tmp/ncl-run-XXXXXX.sh)
  echo "$SCRIPT" > "$TMP"
  chmod +x "$TMP"
  exec bash "$TMP" "$@"
fi

# 2. Process Compose? (has .processes)
if echo "$JSON" | jq_ -e '.processes // empty | keys[0] // empty' &>/dev/null; then
  PROCS=$(echo "$JSON" | jq_ -r '.processes | keys | join(", ")')
  COUNT=$(echo "$JSON" | jq_ '.processes | length')
  echo "==> Detected: process-compose ($COUNT processes: $PROCS)" >&2
  if $DRY_RUN; then exit 0; fi
  TMP=$(mktemp /tmp/ncl-run-XXXXXX.json)
  echo "$JSON" | jq_ . > "$TMP"
  echo "==> Starting process-compose..." >&2
  exec run_pc -f "$TMP" up --tui=false
fi

# 3. GitHub Actions workflow? (has .jobs.*.runs-on) → act
if echo "$JSON" | jq_ -e '.jobs // empty | to_entries[0].value["runs-on"] // empty' &>/dev/null; then
  NAME=$(echo "$JSON" | jq_ -r '.name // "unnamed"')
  RUNNER=$(echo "$JSON" | jq_ -r '[.jobs[]["runs-on"]] | first')
  STEPS=$(echo "$JSON" | jq_ '[.jobs[].steps | length] | add')
  echo "==> Detected: GitHub Actions workflow" >&2
  echo "    Name: $NAME | Runner: $RUNNER | Steps: $STEPS" >&2
  if $DRY_RUN; then exit 0; fi

  TMPDIR=$(mktemp -d /tmp/ncl-run-gha-XXXXXX)
  mkdir -p "$TMPDIR/.github/workflows"
  echo "$JSON" | jq_ . > "$TMPDIR/.github/workflows/run.json"
  echo "==> Running locally with act (requires Docker)..." >&2
  exec run_act -W "$TMPDIR/.github/workflows" push
fi

# 4. Envelope? (has .target.kind) → extract innermost payload, run it
TARGET=$(echo "$JSON" | jq_ -r '.target.kind // empty' 2>/dev/null || true)
if [[ -n "$TARGET" ]]; then
  NAME=$(echo "$JSON" | jq_ -r '.name // "unnamed"')
  NET=$(echo "$JSON" | jq_ -r '.constraints.network.mode // "?"' 2>/dev/null || echo "?")
  FS=$(echo "$JSON" | jq_ -r '.constraints.fs.mode // "?"' 2>/dev/null || echo "?")
  echo "==> Detected: envelope ($TARGET)" >&2
  echo "    Name: $NAME | Network: $NET | FS: $FS" >&2
  if $DRY_RUN; then exit 0; fi

  # Walk to innermost payload
  PAYLOAD_CMD=$(echo "$JSON" | jq_ -r '
    def innermost: if has("inner") then .inner | innermost else . end;
    innermost | .payload |
      if .kind == "nix_flake" then "nix run " + .flake_ref
      elif .kind == "script" then .script // empty
      else .tool_name // empty
      end
  ' 2>/dev/null || true)

  if [[ -z "$PAYLOAD_CMD" || "$PAYLOAD_CMD" == "null" ]]; then
    echo "    No runnable payload in envelope" >&2
    echo "$JSON" | jq_ .
    exit 0
  fi

  echo "    Payload: $PAYLOAD_CMD" >&2

  # On macOS with seatbelt backend, sandbox it
  BACKEND=$(echo "$JSON" | jq_ -r '.target.sandbox_backend // empty' 2>/dev/null || true)
  if [[ "$BACKEND" == "seatbelt" ]] && [[ "$(uname -s)" == "Darwin" ]]; then
    PROFILE="(version 1)\n(allow default)"
    [[ "$NET" == "deny" ]] && PROFILE="$PROFILE\n(deny network-outbound)\n(deny network-inbound)"
    PROFILE_TMP=$(mktemp /tmp/ncl-run-XXXXXX.sb)
    printf '%b' "$PROFILE" > "$PROFILE_TMP"
    echo "==> Running in seatbelt sandbox..." >&2
    exec sandbox-exec -f "$PROFILE_TMP" bash -c "$PAYLOAD_CMD"
  fi

  echo "==> Running payload directly..." >&2
  exec bash -c "$PAYLOAD_CMD"
fi

# 5. porkg? (has .worker.namespaces) → run jobs sequentially
if echo "$JSON" | jq_ -e '.worker.namespaces // empty' &>/dev/null; then
  WNAME=$(echo "$JSON" | jq_ -r '.worker.name // "worker"')
  JOB_COUNT=$(echo "$JSON" | jq_ '.jobs | length')
  NS=$(echo "$JSON" | jq_ -r '[.worker.namespaces | to_entries[] | select(.value) | .key] | join(",")')
  echo "==> Detected: porkg config" >&2
  echo "    Worker: $WNAME | Jobs: $JOB_COUNT | Namespaces: $NS" >&2
  if $DRY_RUN; then exit 0; fi

  echo "==> Running $JOB_COUNT jobs sequentially..." >&2
  FAILED=0
  for i in $(seq 0 $((JOB_COUNT - 1))); do
    JOB_NAME=$(echo "$JSON" | jq_ -r ".jobs[$i].name")
    JOB_CMD=$(echo "$JSON" | jq_ -r ".jobs[$i].command | join(\" \")")
    JOB_ENV=$(echo "$JSON" | jq_ -r ".jobs[$i].env // {} | to_entries[] | \"\(.key)=\(.value)\"" 2>/dev/null || true)

    echo "--- [$((i+1))/$JOB_COUNT] $JOB_NAME: $JOB_CMD" >&2
    # Export env vars individually to handle values with spaces/equals
    while IFS= read -r envline; do
      [[ -n "$envline" ]] && export "$envline"
    done < <(echo "$JSON" | jq_ -r ".jobs[$i].env // {} | to_entries[] | \"\(.key)=\(.value)\"" 2>/dev/null || true)
    bash -c "$JOB_CMD" && echo "    OK" >&2 || { echo "    FAILED" >&2; FAILED=$((FAILED+1)); }
  done
  echo "==> Done: $((JOB_COUNT - FAILED))/$JOB_COUNT passed" >&2
  [[ $FAILED -eq 0 ]] || exit 1
  exit 0
fi

# Fallback
echo "$JSON" | jq_ .
