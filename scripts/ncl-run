#!/usr/bin/env bash
set -euo pipefail

# ncl-run — execute a .ncl file by dispatching to the right runtime
#
# Usage:
#   ncl-run tooling-ncl/examples/markdown-script.ncl < README.md
#   ncl-run process-compose-ncl/examples/standalone-export.ncl
#   ncl-run --dry-run massless-driver/examples/workflow-export.ncl
#   ncl-run --json envelope-ncl/examples/three-layer.ncl

# --- Tool resolution ---
if command -v nickel &>/dev/null; then
  ncl() { nickel "$@"; }
elif command -v nix &>/dev/null; then
  ncl() { nix run nixpkgs#nickel -- "$@"; }
else
  echo "error: nickel not found" >&2; exit 1
fi

if command -v jq &>/dev/null; then
  jq_() { jq "$@"; }
elif command -v nix &>/dev/null; then
  jq_() { nix run nixpkgs#jq -- "$@"; }
else
  echo "error: jq not found" >&2; exit 1
fi

# --- Flags ---
DRY_RUN=false
JSON_ONLY=false
VERBOSE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    --json)    JSON_ONLY=true; shift ;;
    --verbose) VERBOSE=true; shift ;;
    --help|-h)
      echo "ncl-run — export a .ncl file and dispatch to the right runtime"
      echo ""
      echo "Usage: ncl-run [flags] <file.ncl> [-- args...]"
      echo ""
      echo "Flags:"
      echo "  --dry-run    Show what would run, don't execute"
      echo "  --json       Export JSON and stop"
      echo "  --verbose    Show extra detail"
      echo ""
      echo "Dispatches:"
      echo "  .script          → runs the bash script (pipe stdin through it)"
      echo "  .processes       → process-compose up"
      echo "  .jobs.*.runs-on  → writes GHA workflow JSON"
      echo "  .target.kind     → shows envelope info"
      echo "  .worker          → shows porkg config"
      echo "  (version 1)      → writes seatbelt profile"
      exit 0 ;;
    -*) echo "Unknown flag: $1"; exit 1 ;;
    *)  break ;;
  esac
done

NCL_FILE="${1:?Usage: ncl-run <file.ncl>}"
shift || true
[[ -f "$NCL_FILE" ]] || { echo "error: $NCL_FILE not found" >&2; exit 1; }

# --- Step 1: Try seatbelt (text export) ---
TEXT=$(ncl export --format text "$NCL_FILE" 2>/dev/null || true)
if [[ "$TEXT" == "(version 1)"* ]]; then
  echo "==> Detected: seatbelt profile" >&2
  if $DRY_RUN; then
    echo "==> Would run: sandbox-exec -f <profile> <command>" >&2
    exit 0
  fi
  TMP=$(mktemp /tmp/ncl-run-XXXXXX.sb)
  echo "$TEXT" > "$TMP"
  echo "==> Profile: $TMP" >&2
  if [[ $# -gt 0 ]]; then
    echo "==> Running: sandbox-exec -f $TMP $*" >&2
    sandbox-exec -f "$TMP" "$@"
  else
    echo "==> Run: sandbox-exec -f $TMP <command>" >&2
  fi
  exit 0
fi

# --- Step 2: Export JSON ---
JSON=$(ncl export --format json "$NCL_FILE") || { echo "error: export failed" >&2; exit 1; }

if $JSON_ONLY; then
  echo "$JSON" | jq_ .
  exit 0
fi

# --- Step 3: Detect and dispatch ---

# Shell script pipeline? (has .script field)
if echo "$JSON" | jq_ -e '.script // empty' &>/dev/null; then
  SCRIPT=$(echo "$JSON" | jq_ -r '.script')
  LINES=$(echo "$SCRIPT" | wc -l | tr -d ' ')
  echo "==> Detected: shell script ($LINES lines)" >&2
  if $DRY_RUN; then
    echo "$SCRIPT" >&2
    exit 0
  fi
  # Write script to temp, execute it — stdin passes through
  TMP=$(mktemp /tmp/ncl-run-XXXXXX.sh)
  echo "$SCRIPT" > "$TMP"
  chmod +x "$TMP"
  if $VERBOSE; then echo "==> Running: $TMP" >&2; fi
  exec bash "$TMP" "$@"
fi

# Process Compose?
if echo "$JSON" | jq_ -e '.processes // empty | keys[0] // empty' &>/dev/null; then
  PROCS=$(echo "$JSON" | jq_ -r '.processes | keys | join(", ")')
  COUNT=$(echo "$JSON" | jq_ '.processes | length')
  echo "==> Detected: process-compose ($COUNT processes: $PROCS)" >&2
  if $DRY_RUN; then exit 0; fi
  TMP=$(mktemp /tmp/ncl-run-XXXXXX.json)
  echo "$JSON" | jq_ . > "$TMP"
  if command -v process-compose &>/dev/null; then
    echo "==> Starting process-compose..." >&2
    exec process-compose -f "$TMP" up --tui=false
  elif command -v nix &>/dev/null; then
    echo "==> Starting process-compose via nix..." >&2
    exec nix run nixpkgs#process-compose -- -f "$TMP" up --tui=false
  else
    echo "==> Written to $TMP" >&2
    echo "    process-compose -f $TMP up" >&2
    exit 1
  fi
fi

# GitHub Actions workflow?
if echo "$JSON" | jq_ -e '.jobs // empty | to_entries[0].value["runs-on"] // empty' &>/dev/null; then
  NAME=$(echo "$JSON" | jq_ -r '.name // "unnamed"')
  RUNNER=$(echo "$JSON" | jq_ -r '[.jobs[]["runs-on"]] | first')
  STEPS=$(echo "$JSON" | jq_ '[.jobs[].steps | length] | add')
  echo "==> Detected: GitHub Actions workflow" >&2
  echo "    Name: $NAME | Runner: $RUNNER | Steps: $STEPS" >&2
  if $DRY_RUN; then exit 0; fi
  TMP=$(mktemp /tmp/ncl-run-XXXXXX.json)
  echo "$JSON" | jq_ . > "$TMP"
  echo "==> Written to $TMP" >&2
  echo "    cp $TMP .github/workflows/run.json" >&2
  exit 0
fi

# Envelope?
TARGET=$(echo "$JSON" | jq_ -r '.target.kind // empty' 2>/dev/null || true)
if [[ -n "$TARGET" ]]; then
  NAME=$(echo "$JSON" | jq_ -r '.name // "unnamed"')
  NET=$(echo "$JSON" | jq_ -r '.constraints.network.mode // "?"' 2>/dev/null || echo "?")
  FS=$(echo "$JSON" | jq_ -r '.constraints.fs.mode // "?"' 2>/dev/null || echo "?")
  NESTED=$(echo "$JSON" | jq_ 'has("inner")' 2>/dev/null || echo false)
  echo "==> Detected: envelope ($TARGET)" >&2
  echo "    Name: $NAME | Network: $NET | FS: $FS | Nested: $NESTED" >&2
  if $DRY_RUN; then exit 0; fi
  echo "$JSON" | jq_ .
  exit 0
fi

# porkg?
if echo "$JSON" | jq_ -e '.worker.namespaces // empty' &>/dev/null; then
  WNAME=$(echo "$JSON" | jq_ -r '.worker.name // "worker"')
  JOBS=$(echo "$JSON" | jq_ '.jobs | length')
  NS=$(echo "$JSON" | jq_ -r '[.worker.namespaces | to_entries[] | select(.value) | .key] | join(",")')
  echo "==> Detected: porkg config" >&2
  echo "    Worker: $WNAME | Jobs: $JOBS | Namespaces: $NS" >&2
  if $DRY_RUN; then exit 0; fi
  echo "$JSON" | jq_ .
  exit 0
fi

# Fallback — just print
echo "$JSON" | jq_ .
